{
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/site/bin/(.*).zip",
            "headers": [
                {
                    "key": "Content-Disposition",
                    "value": "attachment; filename=$1.zip"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/download",
            "destination": "/site/bin/shortstopper.zip"
        },
        {
            "source": "/(assets|bin)/(.*)",
            "destination": "/site/$1/$2"
        },
        {
            "source": "/(.*)\\.(js|css|json|png|jpg|svg|ico)",
            "destination": "/site/$1.$2"
        },
        {
            "source": "/",
            "destination": "/site/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/site/index.html"
        }
    ]
}