{
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/bin/(.*).zip",
            "headers": [
                {
                    "key": "Content-Disposition",
                    "value": "attachment; filename=$1.zip"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600, must-revalidate"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/download",
            "destination": "/site/bin/shortstopper.zip"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/site/assets/$1"
        },
        {
            "source": "/app.js",
            "destination": "/site/app.js"
        },
        {
            "source": "/styles.css",
            "destination": "/site/styles.css"
        },
        {
            "source": "/manifest.json",
            "destination": "/site/manifest.json"
        },
        {
            "source": "/(.*)",
            "destination": "/site/index.html"
        }
    ]
}