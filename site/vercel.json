{
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/bin/(.*).zip",
            "headers": [
                {
                    "key": "Content-Disposition",
                    "value": "attachment; filename=$1.zip"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600, must-revalidate"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/download",
            "destination": "/bin/shortstopper.zip"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}